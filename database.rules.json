{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (auth.uid === $uid && ((!data.exists() && (auth.token.email_verified === true || newData.child('emailVerificationRequired').val() === true)) || (data.exists() && (!data.child('emailVerificationRequired').exists() || (newData.child('emailVerificationRequired').exists() && newData.child('emailVerificationRequired').val() === data.child('emailVerificationRequired').val()))))))"
      }
    },

    "userRooms": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (auth.uid === $uid && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)))",
        "$roomCode": {
          ".validate": "newData.val() === true || !newData.exists()"
        }
      }
    },

    "roomMembers": {
      "$roomCode": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('roomMembers').child($roomCode).child(auth.uid).exists())",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists() || root.child('roomMembers').child($roomCode).child(auth.uid).exists())",
          ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (auth.uid === $uid && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true) && ((!data.exists() && newData.child('role').val() === 'owner') || (!data.exists() && newData.child('role').val() === 'partner' && newData.child('inviteCode').isString() && root.child('invites').child(newData.child('inviteCode').val()).child('roomCode').val() === $roomCode && root.child('invites').child(newData.child('inviteCode').val()).child('used').val() === false && (!root.child('invites').child(newData.child('inviteCode').val()).child('expiresAt').exists() || root.child('invites').child(newData.child('inviteCode').val()).child('expiresAt').val() >= now)) || (data.exists() && newData.exists() && newData.child('role').val() === data.child('role').val() && newData.child('email').val() === data.child('email').val() && newData.child('joinedAt').val() === data.child('joinedAt').val() && newData.child('inviteCode').val() === data.child('inviteCode').val() && (!data.child('relationshipRole').exists() || newData.child('relationshipRole').val() === data.child('relationshipRole').val())))))",
          ".validate": "!newData.exists() || (newData.child('email').isString() && (newData.child('role').val() === 'owner' || newData.child('role').val() === 'partner' || newData.child('role').val() === 'member') && newData.child('joinedAt').exists() && (!newData.child('relationshipRole').exists() || newData.child('relationshipRole').val() === 'dom' || newData.child('relationshipRole').val() === 'sub'))"
        }
      }
    },

    "rooms": {
      "$roomCode": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('roomMembers').child($roomCode).child(auth.uid).exists())",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('roomMembers').child($roomCode).child(auth.uid).exists() && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)))"
      }
    },

    "ownerNotes": {
      "$roomCode": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('roomMembers').child($roomCode).child(auth.uid).exists())",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('roomMembers').child($roomCode).child(auth.uid).exists() && (root.child('roomMembers').child($roomCode).child(auth.uid).child('role').val() === 'owner' || root.child('roomMembers').child($roomCode).child(auth.uid).child('relationshipRole').val() === 'dom') && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)))"
      }
    },

    "invites": {
      "$code": {
        ".read": "auth != null && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (!data.exists() && newData.child('ownerUid').val() === auth.uid && newData.child('used').val() === false && newData.child('roomCode').isString() && root.child('roomMembers').child(newData.child('roomCode').val()).child(auth.uid).child('role').val() === 'owner' && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)) || (data.exists() && data.child('ownerUid').val() === auth.uid && newData.child('ownerUid').val() === data.child('ownerUid').val() && newData.child('roomCode').val() === data.child('roomCode').val()) || (data.exists() && data.child('used').val() === false && newData.child('used').val() === true && newData.child('usedByUid').val() === auth.uid && newData.child('ownerUid').val() === data.child('ownerUid').val() && newData.child('roomCode').val() === data.child('roomCode').val() && root.child('roomMembers').child(data.child('roomCode').val()).child(auth.uid).exists() && (!data.child('expiresAt').exists() || data.child('expiresAt').val() >= now) && (!root.child('users').child(auth.uid).child('emailVerificationRequired').exists() || auth.token.email_verified === true)))",
        ".validate": "!newData.exists() || (newData.child('roomCode').isString() && newData.child('ownerUid').isString() && newData.child('ownerEmail').isString() && newData.child('createdAt').exists() && newData.child('used').isBoolean())"
      }
    },

    "userAppAccess": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "appAccessRequests": {
      "$appId": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
          ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
        }
      }
    },
    "apps": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$appId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "applications": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$appId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "appRunLogs": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "applicationHistory": {
      "$historyId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "executionLogs": {
      "$logId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "launchTokens": {
      "$token": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "feedbackBoard": {
      "$postId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "userFavorites": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
