{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())"
      }
    },

    "userAppAccess": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "appAccessRequests": {
      "$appId": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
          ".write": "auth != null && ((!data.exists() && auth.uid === $uid && newData.child('status').val() === 'pending') || root.child('admins').child(auth.uid).exists())"
        }
      }
    },

    "apps": {
      ".read": "auth != null",
      "$appId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "applications": {
      ".read": "auth != null",
      "$appId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "appRunLogs": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "applicationHistory": {
      "$historyId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },

    "executionLogs": {
      "$logId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },

    "launchTokens": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "feedbackBoard": {
      "$postId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "userFavorites": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "userRooms": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "roomMembers": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    }
  }
}
