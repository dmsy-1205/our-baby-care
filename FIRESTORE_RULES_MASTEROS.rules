rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MasterOS Platform 승인 문서
    // 문서 ID 예: {MASTER_UID}_hearme2nite
    match /appAccess/{accessId} {
      // 사용자는 자기 승인 상태만 읽을 수 있음
      allow read: if request.auth != null
        && accessId == request.auth.uid + "_hearme2nite";

      // 승인 생성/수정은 플랫폼 관리자 로직에서만 처리해야 함.
      // 기존 플랫폼 관리자 쓰기 규칙이 있으면 그 조건을 여기에 병합하세요.
      allow create, update, delete: if false;
    }

    // 기존 MasterOS Platform 컬렉션 규칙은 아래에 유지/병합하세요.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
